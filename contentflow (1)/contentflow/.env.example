# --- Database (Prisma) ---
# From your Supabase project: Project Settings -> Database -> Connection string
# DATABASE_URL: the pooled connection (port 6543, "Transaction" mode) - used by the app at runtime.
# DIRECT_URL: the direct connection (port 5432) - used only for running migrations.
DATABASE_URL="postgresql://postgres.xxxxx:PASSWORD@aws-0-xx-xxxx-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.xxxxx:PASSWORD@aws-0-xx-xxxx-1.pooler.supabase.com:5432/postgres"

# --- Supabase (Auth + Storage) ---
# From your Supabase project: Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL="https://xxxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-public-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
