// ContentFlow data model.
// Content is the central entity: Ideas Bank, Posts, and Calendar are all
// views over this same table, filtered by `status` / `scheduledAt`.

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Plan {
  starter
  pro
  studio
}

enum MemberRole {
  owner
  editor
  viewer
}

/// What kind of organization this workspace represents - agencies get an
/// extra roster view aggregating their brands; brand and creator keep
/// today's single-brand experience.
enum WorkspaceType {
  brand
  agency
  creator
}

enum ContentType {
  post
  story
  reel
  video
  carousel
}

enum ContentStatus {
  idea
  draft
  scheduled
  published
  archived
}

enum SocialPlatform {
  instagram
  tiktok
  x
  youtube
  linkedin
}

enum SocialAccountStatus {
  connected
  disconnected
  expired
}

enum TaskStatus {
  todo
  in_progress
  done
}

/// Declared low-to-high so `orderBy: { priority: "desc" }` sorts high first -
/// Postgres native enums compare by declaration order.
enum TaskPriority {
  low
  medium
  high
}

enum MessageStatus {
  unread
  read
  replied
}

enum AssistantType {
  trends
  comment_reply
  engagement
  growth
  captions
  viral_ideas
}

/// Mirrors a Supabase Auth user (auth.users). `id` is the same UUID Supabase
/// issues on sign-up — this table is a public-schema profile row, not the
/// auth system itself.
model User {
  id        String            @id @db.Uuid
  email     String            @unique
  name      String?
  createdAt DateTime          @default(now())
  memberships WorkspaceMember[]
  tasks     Task[]
  content   Content[]

  @@map("users")
}

model Workspace {
  id        String            @id @default(uuid())
  name      String
  plan      Plan              @default(starter)
  type      WorkspaceType     @default(brand)
  createdAt DateTime          @default(now())
  members   WorkspaceMember[]
  brands    Brand[]
  content   Content[]
  media     Media[]
  messages  Message[]
  comments  Comment[]
  campaigns Campaign[]
  tasks     Task[]
  creators  Creator[]

  @@map("workspaces")
}

model WorkspaceMember {
  id          String     @id @default(uuid())
  userId      String     @db.Uuid
  workspaceId String
  role        MemberRole @default(owner)
  createdAt   DateTime   @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@map("workspace_members")
}

model Brand {
  id          String   @id @default(uuid())
  workspaceId String
  name        String
  createdAt   DateTime @default(now())

  workspace     Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  brandVoice    BrandVoice?
  content       Content[]
  media         Media[]
  messages      Message[]
  comments      Comment[]
  socialAccounts SocialAccount[]
  campaigns     Campaign[]
  tasks         Task[]

  @@map("brands")
}

/// A group of content to plan and measure together (a launch, a seasonal
/// push, a partnership) - Content.campaignId points here instead of being a
/// free-text label, so totals can't drift from typos across posts.
model Campaign {
  id          String    @id @default(uuid())
  workspaceId String
  brandId     String
  name        String
  description String?   @db.Text
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime  @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  brand     Brand     @relation(fields: [brandId], references: [id], onDelete: Cascade)
  content   Content[]
  media     Media[]
  creators  CampaignCreator[]

  @@index([brandId])
  @@map("campaigns")
}

/// A contact record for an influencer/content creator working on campaigns -
/// not a ContentFlow login, just the roster info an agency or brand needs
/// (name, how to reach them, their own social handles).
model Creator {
  id              String   @id @default(uuid())
  workspaceId     String
  name            String
  contactEmail    String?
  contactPhone    String?
  instagramHandle String?
  tiktokHandle    String?
  notes           String?  @db.Text
  createdAt       DateTime @default(now())

  workspace Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  campaigns CampaignCreator[]

  @@index([workspaceId])
  @@map("creators")
}

model CampaignCreator {
  id         String   @id @default(uuid())
  campaignId String
  creatorId  String
  createdAt  DateTime @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  creator  Creator  @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@unique([campaignId, creatorId])
  @@map("campaign_creators")
}

model BrandVoice {
  id            String   @id @default(uuid())
  brandId       String   @unique
  tone          String?
  wordsToAvoid  String[]
  examplePosts  String[]

  brand Brand @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@map("brand_voices")
}

/// The central entity. Ideas Bank = status "idea"; Posts = status draft /
/// scheduled / published; Calendar = rows with scheduledAt set. Same table,
/// same id, same history — moving between views just changes `status`.
model Content {
  id          String        @id @default(uuid())
  workspaceId String
  brandId     String
  campaignId  String?
  title       String
  body        String?       @db.Text
  type        ContentType
  status      ContentStatus @default(idea)
  platforms   SocialPlatform[]
  scheduledAt DateTime?
  publishedAt DateTime?
  createdBy   String        @db.Uuid
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  /// Set when this row was imported from a connected social account
  /// (the platform's post/media id) instead of authored in ContentFlow.
  externalId   String?
  externalUrl  String?
  /// Refreshed on every sync - the platform's CDN link expires after a
  /// while, so this only stays valid as long as syncing keeps happening.
  thumbnailUrl String?
  /// @usernames parsed out of the caption - pages or other creators tagged
  /// in the post. Instagram doesn't expose a structured mentions list via
  /// this API, so this is extracted from the caption text at sync time.
  mentions     String[] @default([])
  /// The location tag on the post/story, when the author set one - null
  /// when no location was attached.
  locationName String?
  /// Usernames of co-authors on a Collab post. Empty when it's a solo post -
  /// but also empty if this Graph API field turns out unsupported, so this
  /// can't yet be read as a confirmed "not a collab" for every account.
  collaborators String[] @default([])

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  brand     Brand     @relation(fields: [brandId], references: [id], onDelete: Cascade)
  author    User      @relation(fields: [createdBy], references: [id])
  campaign  Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  tasks     Task[]
  media     Media[]
  metrics   Metric[]
  messages  Message[]
  comments  Comment[]

  @@unique([brandId, externalId])
  @@index([workspaceId, status])
  @@index([brandId, status])
  @@index([scheduledAt])
  @@map("content")
}

/// contentId is optional - a task is a reminder first, only sometimes tied
/// to a specific post, so workspaceId/brandId are required directly (same
/// pattern as Message/Media) rather than derived through content.
model Task {
  id          String       @id @default(uuid())
  workspaceId String
  brandId     String
  contentId   String?
  title       String
  dueDate     DateTime?
  status      TaskStatus   @default(todo)
  priority    TaskPriority @default(medium)
  assigneeId  String?      @db.Uuid
  createdAt   DateTime     @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  brand     Brand     @relation(fields: [brandId], references: [id], onDelete: Cascade)
  content   Content?  @relation(fields: [contentId], references: [id], onDelete: SetNull)
  assignee  User?     @relation(fields: [assigneeId], references: [id])

  @@map("tasks")
}

/// contentId and campaignId are both optional and mutually exclusive in
/// practice - a file attaches to a specific post, or to a campaign as a
/// briefing doc, but workspaceId/brandId are always required directly
/// (same pattern as Task/Message) for tenant scoping either way.
model Media {
  id          String   @id @default(uuid())
  workspaceId String
  brandId     String
  contentId   String?
  campaignId  String?
  fileUrl     String
  fileName    String?
  type        String
  uploadedAt  DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  brand     Brand     @relation(fields: [brandId], references: [id], onDelete: Cascade)
  content   Content?  @relation(fields: [contentId], references: [id], onDelete: SetNull)
  campaign  Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@map("media")
}

/// Snapshots over time, not just the latest value — one row per capture.
model Metric {
  id          String         @id @default(uuid())
  contentId   String
  platform    SocialPlatform
  likes       Int            @default(0)
  comments    Int            @default(0)
  shares      Int            @default(0)
  reach       Int            @default(0)
  saved       Int            @default(0)
  videoViews  Int            @default(0)
  impressions Int            @default(0)
  /// Story-only: replies, exits, and forward-taps aren't available for posts/reels.
  replies     Int            @default(0)
  exits       Int            @default(0)
  tapsForward Int            @default(0)
  capturedAt  DateTime       @default(now())

  content Content @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@index([contentId, capturedAt])
  @@map("metrics")
}

model SocialAccount {
  id                 String              @id @default(uuid())
  brandId            String
  platform           SocialPlatform
  oauthAccessToken   String?
  oauthRefreshToken  String?
  status             SocialAccountStatus @default(disconnected)
  connectedAt        DateTime?
  externalAccountId  String?
  externalUsername   String?
  tokenExpiresAt     DateTime?
  lastSyncedAt       DateTime?
  /// Cached from the latest sync - the account snapshots below hold history.
  followersCount     Int?
  followingCount     Int?
  mediaCount         Int?
  profilePictureUrl  String?

  brand        Brand                @relation(fields: [brandId], references: [id], onDelete: Cascade)
  snapshots    AccountSnapshot[]
  demographics AudienceDemographic?

  @@unique([brandId, platform])
  @@map("social_accounts")
}

/// Follower/following counts over time, one row per sync - powers the
/// follower growth chart without needing to re-derive it from Metric rows.
model AccountSnapshot {
  id              String   @id @default(uuid())
  socialAccountId String
  followersCount  Int
  followingCount  Int
  mediaCount      Int
  capturedAt      DateTime @default(now())

  socialAccount SocialAccount @relation(fields: [socialAccountId], references: [id], onDelete: Cascade)

  @@index([socialAccountId, capturedAt])
  @@map("account_snapshots")
}

/// Follower audience breakdown from Instagram's follower_demographics
/// insight - only exposed once an account has 100+ followers, and only ever
/// given as a current lifetime snapshot (no history), so we just overwrite
/// this one row on every sync rather than keeping a time series.
/// Each *Data field is an array of { label: string, value: number } objects.
model AudienceDemographic {
  id              String   @id @default(uuid())
  socialAccountId String   @unique
  genderData      Json
  ageData         Json
  countryData     Json
  cityData        Json
  capturedAt      DateTime @default(now())

  socialAccount SocialAccount @relation(fields: [socialAccountId], references: [id], onDelete: Cascade)

  @@map("audience_demographics")
}

/// contentId is optional (a DM isn't always about one post), but every
/// message still comes in through a specific brand's connected account, so
/// workspaceId/brandId are required for tenant scoping.
model Message {
  id          String         @id @default(uuid())
  workspaceId String
  brandId     String
  contentId   String?
  platform    SocialPlatform
  sender      String
  body        String         @db.Text
  receivedAt  DateTime       @default(now())
  status      MessageStatus  @default(unread)
  /// The platform's message id, so re-syncing doesn't create duplicates.
  externalId  String?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  brand     Brand     @relation(fields: [brandId], references: [id], onDelete: Cascade)
  content   Content?  @relation(fields: [contentId], references: [id], onDelete: SetNull)

  @@unique([brandId, externalId])
  @@index([workspaceId, status])
  @@map("messages")
}

/// A real comment on a post/reel/story, synced from the platform. Replying
/// here calls the platform's actual reply API - it isn't a local-only note.
model Comment {
  id             String        @id @default(uuid())
  workspaceId    String
  brandId        String
  contentId      String
  platform       SocialPlatform
  authorUsername String
  body           String        @db.Text
  publishedAt    DateTime
  status         MessageStatus @default(unread)
  /// What we actually sent back via the platform's reply API, once replied.
  replyText      String?       @db.Text
  repliedAt      DateTime?
  /// The platform's comment id, so re-syncing doesn't create duplicates and
  /// replies can be posted against the right comment.
  externalId     String

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  brand     Brand     @relation(fields: [brandId], references: [id], onDelete: Cascade)
  content   Content   @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@unique([brandId, externalId])
  @@index([workspaceId, status])
  @@map("comments")
}

model AssistantLog {
  id            String        @id @default(uuid())
  assistantType AssistantType
  input         String        @db.Text
  output        String        @db.Text
  createdAt     DateTime      @default(now())

  @@map("assistant_logs")
}
