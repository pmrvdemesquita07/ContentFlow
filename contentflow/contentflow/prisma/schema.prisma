// ContentFlow data model.
// Content is the central entity: Ideas Bank, Posts, and Calendar are all
// views over this same table, filtered by `status` / `scheduledAt`.

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Plan {
  starter
  pro
  studio
}

enum MemberRole {
  owner
  editor
  viewer
}

enum ContentType {
  post
  story
  reel
  video
  carousel
}

enum ContentStatus {
  idea
  draft
  scheduled
  published
  archived
}

enum SocialPlatform {
  instagram
  tiktok
  x
  youtube
  linkedin
}

enum SocialAccountStatus {
  connected
  disconnected
  expired
}

enum TaskStatus {
  todo
  in_progress
  done
}

enum MessageStatus {
  unread
  read
  replied
}

enum AssistantType {
  trends
  comment_reply
  engagement
  growth
  captions
  viral_ideas
}

/// Mirrors a Supabase Auth user (auth.users). `id` is the same UUID Supabase
/// issues on sign-up — this table is a public-schema profile row, not the
/// auth system itself.
model User {
  id        String            @id @db.Uuid
  email     String            @unique
  name      String?
  createdAt DateTime          @default(now())
  memberships WorkspaceMember[]
  tasks     Task[]
  content   Content[]

  @@map("users")
}

model Workspace {
  id        String            @id @default(uuid())
  name      String
  plan      Plan              @default(starter)
  createdAt DateTime          @default(now())
  members   WorkspaceMember[]
  brands    Brand[]
  content   Content[]
  media     Media[]
  messages  Message[]

  @@map("workspaces")
}

model WorkspaceMember {
  id          String     @id @default(uuid())
  userId      String     @db.Uuid
  workspaceId String
  role        MemberRole @default(owner)
  createdAt   DateTime   @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@map("workspace_members")
}

model Brand {
  id          String   @id @default(uuid())
  workspaceId String
  name        String
  createdAt   DateTime @default(now())

  workspace     Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  brandVoice    BrandVoice?
  content       Content[]
  media         Media[]
  messages      Message[]
  socialAccounts SocialAccount[]

  @@map("brands")
}

model BrandVoice {
  id            String   @id @default(uuid())
  brandId       String   @unique
  tone          String?
  wordsToAvoid  String[]
  examplePosts  String[]

  brand Brand @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@map("brand_voices")
}

/// The central entity. Ideas Bank = status "idea"; Posts = status draft /
/// scheduled / published; Calendar = rows with scheduledAt set. Same table,
/// same id, same history — moving between views just changes `status`.
model Content {
  id          String        @id @default(uuid())
  workspaceId String
  brandId     String
  campaignId  String?
  title       String
  body        String?       @db.Text
  type        ContentType
  status      ContentStatus @default(idea)
  platforms   SocialPlatform[]
  scheduledAt DateTime?
  publishedAt DateTime?
  createdBy   String        @db.Uuid
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  /// Set when this row was imported from a connected social account
  /// (the platform's post/media id) instead of authored in ContentFlow.
  externalId  String?
  externalUrl String?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  brand     Brand     @relation(fields: [brandId], references: [id], onDelete: Cascade)
  author    User      @relation(fields: [createdBy], references: [id])
  tasks     Task[]
  media     Media[]
  metrics   Metric[]
  messages  Message[]

  @@unique([brandId, externalId])
  @@index([workspaceId, status])
  @@index([brandId, status])
  @@index([scheduledAt])
  @@map("content")
}

model Task {
  id         String     @id @default(uuid())
  contentId  String
  title      String
  dueDate    DateTime?
  status     TaskStatus @default(todo)
  assigneeId String?    @db.Uuid
  createdAt  DateTime   @default(now())

  content  Content @relation(fields: [contentId], references: [id], onDelete: Cascade)
  assignee User?   @relation(fields: [assigneeId], references: [id])

  @@map("tasks")
}

model Media {
  id          String   @id @default(uuid())
  workspaceId String
  brandId     String
  contentId   String?
  fileUrl     String
  type        String
  uploadedAt  DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  brand     Brand     @relation(fields: [brandId], references: [id], onDelete: Cascade)
  content   Content?  @relation(fields: [contentId], references: [id], onDelete: SetNull)

  @@map("media")
}

/// Snapshots over time, not just the latest value — one row per capture.
model Metric {
  id         String         @id @default(uuid())
  contentId  String
  platform   SocialPlatform
  likes      Int            @default(0)
  comments   Int            @default(0)
  shares     Int            @default(0)
  reach      Int            @default(0)
  capturedAt DateTime       @default(now())

  content Content @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@index([contentId, capturedAt])
  @@map("metrics")
}

model SocialAccount {
  id                String              @id @default(uuid())
  brandId           String
  platform          SocialPlatform
  oauthAccessToken  String?
  oauthRefreshToken String?
  status            SocialAccountStatus @default(disconnected)
  connectedAt       DateTime?
  externalAccountId String?
  externalUsername  String?
  tokenExpiresAt    DateTime?
  lastSyncedAt      DateTime?

  brand Brand @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@unique([brandId, platform])
  @@map("social_accounts")
}

/// contentId is optional (a DM isn't always about one post), but every
/// message still comes in through a specific brand's connected account, so
/// workspaceId/brandId are required for tenant scoping.
model Message {
  id          String         @id @default(uuid())
  workspaceId String
  brandId     String
  contentId   String?
  platform    SocialPlatform
  sender      String
  body        String         @db.Text
  receivedAt  DateTime       @default(now())
  status      MessageStatus  @default(unread)
  /// The platform's message id, so re-syncing doesn't create duplicates.
  externalId  String?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  brand     Brand     @relation(fields: [brandId], references: [id], onDelete: Cascade)
  content   Content?  @relation(fields: [contentId], references: [id], onDelete: SetNull)

  @@unique([brandId, externalId])
  @@index([workspaceId, status])
  @@map("messages")
}

model AssistantLog {
  id            String        @id @default(uuid())
  assistantType AssistantType
  input         String        @db.Text
  output        String        @db.Text
  createdAt     DateTime      @default(now())

  @@map("assistant_logs")
}
